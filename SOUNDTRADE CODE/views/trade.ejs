<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Trade | SoundTrade</title>
  <link rel="stylesheet" href="/css/navbar.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include("partials/navbar") %>

  <main class="trade-page">
    <section class="trade-header">
      <p class="section-tag">SKILL TRADE</p>
      <h1>Plan Your Skill Exchange</h1>
      <p class="results-subtext">
        Connect, chat, and organize how you want to teach and learn together.
      </p>
    </section>

    <section class="trade-card">
      <div class="trade-info">
        <h2>Trade Details</h2>

        <div class="trade-detail-list">
          <p>
            <strong>You:</strong>
            <%= currentUser ? currentUser.username : "Guest User" %>
          </p>

          <p>
            <strong>Trading With:</strong>
            <%= partner ? partner.username : "Other User" %>
          </p>

          <p>
            <strong>Skill Offered:</strong>
            <%= tradePost ? tradePost.knows : "Not specified" %>
          </p>

          <p>
            <strong>Skill Wanted:</strong>
            <%= tradePost ? tradePost.wants : "Not specified" %>
          </p>
        </div>
      </div>

      <div class="trade-actions">
        <h2>Trade Status</h2>

        <div class="trade-status-box">
          <p>
            <strong>Status:</strong>
            <%= tradePost && tradePost.accepted ? "Accepted" : "Pending" %>
          </p>
        </div>

        <% if (tradePost) { %>
          <form action="/trade/accept" method="POST">
            <input type="hidden" name="postId" value="<%= tradePost._id %>">
            <button type="submit" class="trade-btn">Accept Trade</button>
          </form>
        <% } else { %>
          <button type="button" class="trade-btn disabled-btn" disabled>No Trade Selected</button>
        <% } %>
      </div>
    </section>

    <section class="chat-section">
      <h2>Messages</h2>

      <div class="chat-box">
        <% if (messages && messages.length > 0) { %>
          <% messages.forEach(message => { %>
            <div class="chat-message">
              <p><strong><%= message.sender %>:</strong> <%= message.text %></p>
            </div>
          <% }) %>
        <% } else { %>
          <p class="empty-chat-text">No messages yet. Start the conversation below.</p>
        <% } %>
      </div>

      <form action="/trade/message" method="POST" class="chat-form">
        <% if (tradePost) { %>
          <input type="hidden" name="postId" value="<%= tradePost._id %>">
        <% } %>

        <textarea
          name="message"
          rows="4"
          placeholder="Type your message here..."
          required
        ></textarea>

        <button type="submit" class="trade-btn">Send Message</button>
      </form>
    </section>

    <section class="trade-note">
      <h2>Next Step</h2>
      <p>
        Use the chat to decide how you will learn from each other, when you will meet,
        and whether the session will be online or in person.
      </p>
    </section>
  </main>

  <%- include("partials/footer") %>

</body>
</html>