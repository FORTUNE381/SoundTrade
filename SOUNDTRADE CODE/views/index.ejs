<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SoundTrade</title>
  <link rel="stylesheet" href="/css/navbar.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include("partials/navbar") %>

  <main class="hero-page">
    <section class="hero-section">
      <p class="section-tag">MUSIC SKILL EXCHANGE</p>
      <h1>Trade Your Music Skills</h1>
      <p class="hero-subtext">
        Learn guitar, piano, vocals, and more by exchanging the skills you already
        have with others.
      </p>

      <p class="hero-note">
        *You will have to log in or sign up before you begin trading
      </p>

      <form action="/search" method="POST" class="search-form">
        <div class="field-group">
          <label for="knowSkill">I know...</label>
          <input
            type="text"
            id="knowSkill"
            name="knowSkill"
            placeholder="Example: Guitar"
            required
          >
        </div>

        <div class="field-group">
          <label for="learnSkill">I want to learn...</label>
          <input
            type="text"
            id="learnSkill"
            name="learnSkill"
            placeholder="Example: Piano"
            required
          >
        </div>

        <button type="submit" class="btn btn-primary">Find Match</button>
      </form>
    </section>

    <section class="how-section">
      <div class="how-container">
        <p class="how-tag">HOW IT WORKS</p>
        <h2>Start Learning Through Skill Exchange</h2>

        <div class="how-list">
          <div class="how-item">
            <div class="how-icon">⌕</div>
            <div class="how-text">
              <h3>Search Skills</h3>
              <p>
                Enter the music skill you already know and the one you want to
                learn.
              </p>
            </div>
          </div>

          <div class="how-item">
            <div class="how-icon">👥</div>
            <div class="how-text">
              <h3>Find a Match</h3>
              <p>
                Browse users with compatible music skill trades in a clean
                card-based view.
              </p>
            </div>
          </div>

          <div class="how-item">
            <div class="how-icon">💬</div>
            <div class="how-text">
              <h3>Start Trading</h3>
              <p>
                Connect through messages and decide how you want to teach and
                learn together.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include("partials/footer") %>
</body>
</html>
