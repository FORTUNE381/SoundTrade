<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SoundTrade</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  <link rel="stylesheet" href="/css/navbar.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include("partials/navbar") %>

  <main>
    <section class="hero">
      <div class="container hero-content">
        <p class="hero-tag">MUSIC SKILL EXCHANGE</p>
        <h1>Trade Your Music Skills</h1>

        <p class="hero-description">
          Learn guitar, piano, vocals, and more by exchanging the skills you already have with others.
        </p>

        <form class="search-box" action="/search" method="GET">
          <div class="field-group">
            <label for="skillOffered">I know</label>
            <input
              type="text"
              id="skillOffered"
              name="skillOffered"
              placeholder="e.g. Guitar"
              required
            >
          </div>

          <div class="field-group">
            <label for="skillWanted">I want to learn</label>
            <input
              type="text"
              id="skillWanted"
              name="skillWanted"
              placeholder="e.g. Piano"
              required
            >
          </div>

          <button type="submit" class="btn btn-primary">Find Match</button>
        </form>
      </div>
    </section>

    <section class="how-it-works">
      <div class="how-left">
        <p class="section-tag">HOW IT WORKS</p>
        <h2>Start Learning Through Skill Exchange</h2>

        <div class="how-step">
          <div class="step-icon">
            <i class="fa-solid fa-magnifying-glass"></i>
          </div>
          <div class="step-text">
            <h3>Search Skills</h3>
            <p>Enter the music skill you already know and the one you want to learn.</p>
          </div>
        </div>

        <div class="how-step">
          <div class="step-icon">
            <i class="fa-solid fa-user-group"></i>
          </div>
          <div class="step-text">
            <h3>Find a Match</h3>
            <p>Browse users with compatible music skill trades in a clean card-based view.</p>
          </div>
        </div>

        <div class="how-step">
          <div class="step-icon">
            <i class="fa-solid fa-comments"></i>
          </div>
          <div class="step-text">
            <h3>Start Trading</h3>
            <p>Connect through messages and decide how you want to teach and learn together.</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <%- include("partials/footer") %>
</body>
</html>